{
  "enabled": true,
  "name": "csv-data",
  "when": {
    "exts": [
      ".csv",
      ".tsv",
      ".parquet"
    ],
    "kind": "fileExt"
  },
  "then": {
    "command": "codex --no-alt-screen --sandbox workspace-write -a never -c 'developer_instructions={spauwnAgentInstructionsTomlString}'",
    "adapter": "richProcess",
    "cwd": "fileDirGitRoot",
    "tools": [
      "injectWindowScreenshot",
      "injectScreenshotBelow"
    ],
    "statePatterns": {
      "busy": [
        "^(Thinking|Working|\\[Esc\\]|Loading)"
      ],
      "idle": [
        "[▌►]|>\\s*$|\\(y/n\\)"
      ]
    },
    "injectFiles": [
      {
        "from": "{spauwnAgentSkill}",
        "to": "{sessionDir}/.agents/skills/spauwn/SKILL.md",
        "symlink": true
      }
    ]
  }
}
