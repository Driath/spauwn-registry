    { "from": "files/03_web.json", "to": "gambits/03_web.json" },
    { "from": "files/04_terminal.json", "to": "gambits/04_terminal.json" },
    { "from": "files/05_csv-data.json", "to": "gambits/05_csv-data.json" },
    { "from": "files/06_file.json", "to": "gambits/06_file.json" },
    { "from": "files/07_editor.json", "to": "gambits/07_editor.json" },
    { "from": "files/08_finder.json", "to": "gambits/08_finder.json" },
